# Environment Variables
# Copy this file to .env.local and fill in actual values

# Site URL (for SEO and sitemap generation)
NEXT_PUBLIC_SITE_URL=https://theblackbarber.com

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Booking System (future extension)
# NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Contact Form (optional - if using a form service)
# CONTACT_FORM_API_KEY=your-api-key
